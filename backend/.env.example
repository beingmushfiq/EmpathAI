# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/empathai

# ─── Auth (Clerk) ────────────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here
CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here
CLERK_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ─── OpenAI ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# ─── Anthropic (optional alternative to OpenAI) ───────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here

# ─── ElevenLabs TTS ─────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# ─── Deepgram STT ───────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# ─── Pinecone Vector DB ──────────────────────────────────────────────────────
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX_NAME=empathai-memory

# ─── HeyGen (Avatar Streaming) ───────────────────────────────────────────────
HEYGEN_API_KEY=your_heygen_api_key_here

# ─── App Settings ────────────────────────────────────────────────────────────
SECRET_KEY=your_super_secret_jwt_key_change_this_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ─── CORS ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://your-production-domain.com

# ─── Environment ─────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
